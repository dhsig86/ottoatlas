# ============================================================
# OTTO ATLAS — .gitignore
# Repositório contém apenas: Frontend (Vercel) + Backend (Render)
# Mídia e modelos ML vivem em Cloudinary / Render Disk / fora do Git
# ============================================================

# --- Dependências ---
node_modules/
dist/

# --- Variáveis de Ambiente (segredos) ---
.env
.env.local
.env.*.local

# --- Modelos de ML (Render usa Disk persistente ou download sob demanda) ---
*.onnx
*.onnx.data
*.pkl
*.pt
*.pth
*.h5
*.safetensors

# --- Dados pesados / datasets ---
*.zip
*.tar.gz
*.dump
*.sql
kaggle_export/
OTTO_ML_Dataset/
OTTO_ML_Dataset_Raw/
../OTTO_ML_Dataset
../APPROTTO

# --- Logs e arquivos temporários ---
*.log
logs/*.txt
temp_*.txt
uvi_*.txt
output_paths.txt

# --- Cache Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
.eggs/

# --- Ambiente Virtual Python ---
ml_pipeline/venv/
venv/
.venv/
env/

# --- IDEs e OS ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Build artifacts ---
*.pyc
build/

.vercel
